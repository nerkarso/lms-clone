{
  "name": "lms",
  "type": "module",
  "scripts": {
    "dev": "nodemon --env-file=.env server.js",
    "start": "node --env-file=.env server.js",
    "start:prod": "node server.js",
    "db:setup": "node --env-file=.env scripts/db-setup.js",
    "db:seed": "node --env-file=.env scripts/db-seed.js",
    "format": "npx prettier --write .",
    "test": "npm run test:e2e",
    "test:e2e": "node --env-file=.env.test --test tests/e2e/*.test.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "prettier": {
    "arrowParens": "always",
    "printWidth": 100,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}

<%- include('../layout-head') %>

<section class="panel narrow">
  <h1><%= title %></h1>

  <% if (errors.length > 0) { %>
    <ul class="error">
      <% errors.forEach((error) => { %>
        <li><%= error %></li>
      <% }) %>
    </ul>
  <% } %>

  <form action="<%= action %>" method="post" class="form">
    <label>
      Title
      <input type="text" name="title" value="<%= values.title || '' %>" required />
    </label>

    <label>
      Description
      <textarea name="description" rows="5"><%= values.description || '' %></textarea>
    </label>

    <button type="submit">Save course</button>
  </form>
</section>

<%- include('../layout-foot') %>
